# Frontend configuration — FTA §14.
# PUBLIC values only. Anything shipped to a browser is public; minification is
# not concealment. Secrets belong behind a backend endpoint, never here.
#
# Loaded per Vite mode:
#   development -> .env.development   (committed)
#   test        -> .env.test          (committed; MUST point at localhost)
#   staging     -> supplied by the deploy/CI environment
#   production  -> supplied by the deploy/CI environment
#
# Required in every environment:
VITE_API_BASE_URL=http://127.0.0.1:8000/api/v1
